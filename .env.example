# Authentication (optional — defaults to Admin/Admin if not set)
ADMIN_USERNAME=Admin
ADMIN_PASSWORD=Admin

# AI Features (optional — Advanced mode features require these)
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AI...

# Supabase (for estimate history, saved projects, pgvector)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# monday.com Integration (optional)
MONDAY_API_TOKEN=

# Map Workspace (optional — enables satellite map drawing workspace)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-token
NEXT_PUBLIC_MAP_WORKSPACE=true

# Google Maps Street View (optional — enables Street View panel and AI ground-level analysis)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-api-key
GEMINI_API_KEY=your-gemini-api-key

# Media capture + AI rendering pipeline (Swarm D Task #7)
# Server-side key preferred for Static API calls (higher-volume capture).
# Falls back to NEXT_PUBLIC_GOOGLE_MAPS_KEY if unset.
GOOGLE_MAPS_SERVER_KEY=
AI_RENDERING_ENABLED=false
AI_RENDER_PROVIDER=disabled
GEMINI_API_KEY=
FAL_API_KEY=
AI_RENDER_MAX_USD_PER_PROJECT=5
